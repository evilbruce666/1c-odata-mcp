{
  "name": "1c-odata-mcp",
  "version": "0.1.2",
  "description": "MCP server for 1C (1С:Предприятие) via the standard OData interface. High-level tools for executives and accountants: read by default, with opt-in (gated) write.",
  "type": "module",
  "bin": {
    "1c-odata-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evilbruce666/1c-odata-mcp.git"
  },
  "homepage": "https://github.com/evilbruce666/1c-odata-mcp#readme",
  "bugs": {
    "url": "https://github.com/evilbruce666/1c-odata-mcp/issues"
  },
  "author": "evilbruce666",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "probe": "node dist/scripts/probe-metadata.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && node --eval \"require('fs').rmSync('dist/scripts',{recursive:true,force:true})\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "1c",
    "1с",
    "odata",
    "scloud",
    "accounting",
    "erp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fast-xml-parser": "^4.5.0",
    "pino": "^9.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
