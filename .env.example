# ─────────────────────────────────────────────────────────────
# Подключение к OData-интерфейсу 1С (Scloud)
# ─────────────────────────────────────────────────────────────

# Базовый URL стандартного интерфейса OData.
# Scloud имеет вид: https://terminal.scloud.ru/01/<ваша_база>/odata/standard.odata/
# ВАЖНО: оставляйте завершающий слэш.
ODATA_BASE_URL=https://terminal.scloud.ru/01/login_base01/odata/standard.odata/

# Basic Auth — учётные данные пользователя 1С (для Scloud совпадают с облачной учёткой).
# Рекомендуется отдельный пользователь с правами ТОЛЬКО на чтение нужных объектов.
ODATA_USERNAME=your_user
ODATA_PASSWORD=your_password

# ─────────────────────────────────────────────────────────────
# Поведение клиента
# ─────────────────────────────────────────────────────────────

# Таймаут одного HTTP-запроса, мс.
ODATA_TIMEOUT_MS=30000

# Число повторов при 429/5xx/сетевых сбоях.
ODATA_RETRIES=3

# Размер страницы по умолчанию ($top).
ODATA_PAGE_SIZE=100

# Защитный максимум строк, которые инструмент вернёт за один вызов.
ODATA_MAX_ROWS=1000

# Уровень логирования: trace|debug|info|warn|error. Логи идут в stderr.
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# Жёсткий режим только-чтение. Менять на false на 1-м этапе ЗАПРЕЩЕНО.
# ─────────────────────────────────────────────────────────────
READ_ONLY=true
