# ─────────────────────────────────────────────────────────────
# Подключение к OData-интерфейсу 1С
#
# Работает с любой 1С, где опубликован стандартный интерфейс OData
# (своя публикация IIS/Apache, хостинг 1cfresh, Scloud и т.п.).
# Общий вид адреса (со слэшем на конце):
#   https://<сервер>/<имя_базы>/odata/standard.odata/
#
# Вариант A — ОДНА база (просто): задайте три переменные ниже.
# Вариант Б — НЕСКОЛЬКО баз: закомментируйте блок A и используйте блок Б.
# Тонкости авторизации по площадкам — в docs/CONNECTING.md.
# ─────────────────────────────────────────────────────────────

# ── A. Одна база ──
ODATA_BASE_URL=https://<сервер>/<имя_базы>/odata/standard.odata/
ODATA_USERNAME=your_user
ODATA_PASSWORD=your_password
# Необязательно: имя/ярлык одиночной базы (по умолчанию имя "default").
# ODATA_DB_NAME=buh
# ODATA_DB_LABEL=Бухгалтерия ООО «Ромашка»

# ── Б. Несколько баз ──
# Каждая база — тройка ODATA_DB_<ИМЯ>_BASE_URL / _USERNAME / _PASSWORD
# (+ необязательный _LABEL). <ИМЯ> латиницей, оно же идёт в параметр database
# инструментов. Полный список — через инструмент list_databases.
#
# ODATA_DB_BUH_BASE_URL=https://<сервер>/<база1>/odata/standard.odata/
# ODATA_DB_BUH_USERNAME=login_1
# ODATA_DB_BUH_PASSWORD=secret1
# ODATA_DB_BUH_LABEL=Бухгалтерия (ООО «Ромашка»)
#
# ODATA_DB_TORG_BASE_URL=https://<сервер>/<база2>/odata/standard.odata/
# ODATA_DB_TORG_USERNAME=login_2
# ODATA_DB_TORG_PASSWORD=secret2
# ODATA_DB_TORG_LABEL=Торговля (ИП Иванов)
#
# База по умолчанию (если параметр database не указан; иначе — первая по алфавиту):
# ODATA_DEFAULT_DB=buh

# ─────────────────────────────────────────────────────────────
# ЗАПИСЬ (создание/изменение данных). По умолчанию ВЫКЛЮЧЕНА.
#
# Чтобы разрешить запись, нужно снять ДВА предохранителя:
#   1) глобально:        READ_ONLY=false   (см. ниже)
#   2) на нужной базе:    ODATA_DB_<ИМЯ>_WRITABLE=true
# Базы без WRITABLE=true остаются только на чтение даже при READ_ONLY=false.
# Так можно открыть запись в одну базу и защитить остальные.
#
# Пример: писать в IP, а BUH/TORG держать read-only:
# ODATA_DB_IP_WRITABLE=true
# ODATA_DB_BUH_WRITABLE=false   # (можно не указывать — по умолчанию false)
#
# Для одиночной базы (блок A) — общий флаг:
# ODATA_WRITABLE=true

# ─────────────────────────────────────────────────────────────
# Поведение клиента
# ─────────────────────────────────────────────────────────────

# Таймаут одного HTTP-запроса, мс.
ODATA_TIMEOUT_MS=30000

# Число повторов при 429/5xx/сетевых сбоях.
ODATA_RETRIES=3

# Размер страницы по умолчанию ($top).
ODATA_PAGE_SIZE=100

# Защитный максимум строк, которые инструмент вернёт за один вызов.
ODATA_MAX_ROWS=1000

# Потолок строк для АГРЕГАТОРОВ (get_*_breakdown, get_taxes_paid, get_deal_history):
# они только суммируют и наружу строки не отдают, поэтому лимит высокий — иначе
# годовые итоги по «шумным» базам занижаются. Снижать только при проблемах с памятью.
ODATA_ANALYTICS_MAX_ROWS=200000

# Уровень логирования: trace|debug|info|warn|error. Логи идут в stderr.
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# Глобальный режим только-чтение (главный рубильник).
# true  — вся запись запрещена (безопасно по умолчанию).
# false — запись разрешается, НО только для баз с ODATA_DB_<ИМЯ>_WRITABLE=true.
# ─────────────────────────────────────────────────────────────
READ_ONLY=true
